{
  "name": "forgedesk",
  "version": "0.9.1",
  "description": "A local auto-capture desk for AI-assisted code changes.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lucy77m/ForgeDesk.git"
  },
  "bugs": {
    "url": "https://github.com/Lucy77m/ForgeDesk/issues"
  },
  "homepage": "https://github.com/Lucy77m/ForgeDesk#readme",
  "keywords": [
    "ai-assisted-development",
    "code-review",
    "cli",
    "evidence",
    "git",
    "local-first",
    "pr"
  ],
  "packageManager": "pnpm@11.1.3",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "forgedesk": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts",
    "package-smoke": "tsx scripts/package-smoke.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
